# brew/cli.Brewfile — utilidades de terminal (formulae).
# Se instala con: just cli   (en macOS)

brew "git"        # control de versiones
brew "gh"         # GitHub CLI
brew "just"       # este mismo task runner
brew "ripgrep"    # rg — grep rapido
brew "fd"         # find moderno
brew "fzf"        # fuzzy finder
brew "bat"        # cat con colores
brew "eza"        # ls moderno
brew "zoxide"     # cd inteligente
