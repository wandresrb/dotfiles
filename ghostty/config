# Ghostty — config gestionada en dotfiles (symlink a ~/.config/ghostty).
# Instala con: just ghostty-config
# Recarga en caliente: Cmd+Shift+, — Docs: https://ghostty.org/docs/config

# --- Apariencia ---
theme = Catppuccin Mocha
background-opacity = 0.97
font-family = "JetBrainsMono Nerd Font"   # descomenta tras instalar la fuente
font-size = 15

# --- Ventana ---
window-padding-x = 10
window-padding-y = 8
macos-titlebar-style = tabs
mouse-hide-while-typing = true

# --- Comportamiento ---
copy-on-select = clipboard
confirm-close-surface = false
